# Base URL for the GoalKeeper Dash backend API.
# All endpoints are mounted under /api/v1 on top of this base URL.
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080

# OIDC client IDs used by expo-auth-session for Google sign-in.
# Create OAuth 2.0 client IDs in Google Cloud Console (one per platform).
EXPO_PUBLIC_GOOGLE_CLIENT_ID_IOS=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=
EXPO_PUBLIC_GOOGLE_CLIENT_ID_WEB=

# Facebook Login App ID (Facebook for Developers > Settings > Basic).
EXPO_PUBLIC_FACEBOOK_APP_ID=

# Optional: EAS project id, only needed for EAS builds/updates.
EXPO_PUBLIC_EAS_PROJECT_ID=
