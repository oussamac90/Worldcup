# Copy to .env and fill in real secrets/IdP IDs before `docker compose up`.

# ---- Postgres ----
POSTGRES_DB=goalkeeper
POSTGRES_USER=gk
POSTGRES_PASSWORD=change_me

# ---- Spring datasource (constructed from the above by compose for the api service) ----
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/goalkeeper
SPRING_DATASOURCE_USERNAME=gk
SPRING_DATASOURCE_PASSWORD=change_me
# dev/local: update | prod: validate (see README "Prod notes")
SPRING_JPA_HIBERNATE_DDL_AUTO=update

# ---- Redis ----
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

# ---- App JWT (MUST be >= 32 bytes) ----
APP_JWT_SECRET=change_me_long_random_at_least_32_bytes_please
APP_JWT_ACCESS_TTL_MIN=30
APP_JWT_REFRESH_TTL_DAYS=30

# ---- IdP client IDs (server-side OIDC token verification) ----
GOOGLE_CLIENT_ID=
FACEBOOK_APP_ID=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
# Local dev login path (NO real IdP). MUST be false in prod.
APP_OIDC_DEV_LOGIN_ENABLED=true

# ---- Seeding ----
APP_SEED_ENABLED=true
APP_SEED_SIMULATED_NATIONS=true

# ---- Back-office bootstrap admin ----
ADMIN_BOOTSTRAP_USER=admin
ADMIN_BOOTSTRAP_PASSWORD=change_me

# ---- CORS (Expo dev origins + prod app) ----
APP_CORS_ALLOWED_ORIGINS=http://localhost:8081,http://localhost:19006
